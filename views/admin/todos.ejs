<%- include("../partials/header.ejs") %>

<body style="background-color: #f8fafb;">

  <%- include("../partials/navbar.ejs") %>
  <div class="container py-5">

    <div class="text-center mb-5">
  
      <p
        class="mb-2"
        style="
          color: #21708c;
          font-weight: 700;
          letter-spacing: 1px;
          text-transform: uppercase;
          font-size: 14px;
        "
      >
        Administración
      </p>
  
      <h1
        class="fw-bold"
        style="
          font-size: clamp(2.8rem, 5vw, 4rem);
        "
      >
        Todos los proyectos
      </h1>
  
      <p
        class="mt-3"
        style="
          color: #5f6b73;
          font-size: 1.05rem;
        "
      >
        Gestioná el estado de los proyectos presentados en la feria.
      </p>
  
    </div>
  
    <div class="d-flex justify-content-end mb-4">
  
      <a
        href="/admin"
        class="btn px-4 py-2"
        style="
          border: 2px solid #21708c;
          color: #21708c;
          border-radius: 14px;
          font-weight: 700;
        "
      >
        Volver al panel
      </a>
  
    </div>
  
    <div
    class="table-responsive"
    style="
      background-color: white;
      border-radius: 28px;
      overflow: hidden;
      box-shadow: 0 12px 30px rgba(0,0,0,0.06);
    "
  >
  
    <table class="table table-hover align-middle mb-0">
  
      <thead>
  
        <tr
          style="
            background-color: #21708c;
            color: white;
          "
        >
          <th class="ps-4 py-4">Título</th>
          <th>Autor</th>
          <th>Categoría</th>
          <th>Escuela</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
  
      </thead>
  
      <tbody>
  
        <% proyectos.forEach(proyecto => { %>
  
        <tr>
  
          <td class="fw-semibold ps-4">
            <%= proyecto.titulo %>
          </td>
  
          <td>
            <%= proyecto.autor ? proyecto.autor.nombre : "--" %>
          </td>
  
          <td>
            <%= proyecto.categoria.nombre %>
          </td>
  
          <td>
            <%= proyecto.escuela ? proyecto.escuela.nombre : "--" %>
          </td>
  
          <td>
  
            <% if (proyecto.estado === "aprobado") { %>
  
              <span class="badge bg-success">
                Aprobado
              </span>
  
            <% } else if (proyecto.estado === "rechazado") { %>
  
              <span class="badge bg-danger">
                Rechazado
              </span>
  
            <% } else { %>
  
              <span class="badge bg-warning text-dark">
                Pendiente
              </span>
  
            <% } %>
  
          </td>
  
          <td>
  
            <div class="d-flex gap-2">
  
              <% if (proyecto.estado !== "aprobado") { %>
  
                <form action="/admin/<%= proyecto.id %>/aprobar" method="POST">
  
                  <button
                    type="submit"
                    class="btn btn-sm"
                    style="
                      background-color: #21708c;
                      color: white;
                      border-radius: 10px;
                    "
                  >
                    Aprobar
                  </button>
  
                </form>
  
              <% } %>
  
              <% if (proyecto.estado !== "rechazado") { %>
  
                <form action="/admin/<%= proyecto.id %>/rechazar" method="POST">
  
                  <button
                    type="submit"
                    class="btn btn-sm btn-outline-danger"
                    style="
                      border-radius: 10px;
                    "
                  >
                    Rechazar
                  </button>
  
                </form>
  
              <% } %>
  
            </div>
  
          </td>
  
        </tr>
  
        <% }) %>
  
      </tbody>
  
    </table>
  
  </div>
  
  </div>
</body>
<%- include("../partials/footer.ejs") %>