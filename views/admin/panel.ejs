<%- include("../partials/header.ejs") %>

<body style="background-color: #f8fafb;">

  <%- include("../partials/navbar.ejs") %>

  <div class="container py-5">

    <div class="text-center mb-5">

      <p
        class="mb-2"
        style="
          color: #21708c;
          font-weight: 700;
          letter-spacing: 1px;
          text-transform: uppercase;
          font-size: 14px;
        "
      >
        Administración
      </p>

      <h1
        class="fw-bold"
        style="
          font-size: clamp(2.8rem, 5vw, 4rem);
        "
      >
        Panel de administración
      </h1>

      <p
        class="mt-3"
        style="
          color: #5f6b73;
          font-size: 1.05rem;
        "
      >
        Revisá y moderá los proyectos pendientes de aprobación.
      </p>

    </div>

    <div class="d-flex justify-content-end mb-4">

      <a
        href="/admin/todos"
        class="btn px-4 py-2"
        style="
          border: 2px solid #21708c;
          color: #21708c;
          border-radius: 14px;
          font-weight: 700;
        "
      >
        Ver todos los proyectos
      </a>

    </div>

    <% if (proyectosPendientes.length > 0) { %>

      <div
        class="table-responsive"
        style="
          background-color: white;
          border-radius: 28px;
          overflow: hidden;
          box-shadow: 0 12px 30px rgba(0,0,0,0.06);
        "
      >

        <table class="table table-hover align-middle mb-0">

          <thead>

            <tr
              style="
                background-color: #21708c;
                color: white;
              "
            >
              <th class="ps-4 py-4">Título</th>
              <th>Escuela</th>
              <th>Categoría</th>
              <th>Profesor</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>

          </thead>

          <tbody>

            <% proyectosPendientes.forEach(proyecto => { %>

            <tr>

              <td class="fw-semibold ps-4">
                <%= proyecto.titulo %>
              </td>

              <td>
                <%= proyecto.escuela.nombre %>
              </td>

              <td>
                <%= proyecto.categoria.nombre %>
              </td>

              <td>
                <%= proyecto.autor.nombre %>
              </td>

              <td>
                <span class="badge bg-warning text-dark">
                  <%= proyecto.estado %>
                </span>
              </td>

              <td>

                <div class="d-flex gap-2">

                  <form action="/admin/<%= proyecto.id %>/aprobar" method="POST">

                    <button
                      type="submit"
                      class="btn btn-sm"
                      style="
                        background-color: #21708c;
                        color: white;
                        border-radius: 10px;
                      "
                    >
                      Aprobar
                    </button>

                  </form>

                  <form action="/admin/<%= proyecto.id %>/rechazar" method="POST">

                    <button
                      type="submit"
                      class="btn btn-sm btn-outline-danger"
                      style="
                        border-radius: 10px;
                      "
                    >
                      Rechazar
                    </button>

                  </form>

                </div>

              </td>

            </tr>

            <% }) %>

          </tbody>

        </table>

      </div>

    <% } else { %>

      <div
        class="d-flex align-items-center justify-content-center"
        style="
          min-height: 220px;
          background-color: white;
          border-radius: 28px;
          box-shadow: 0 12px 30px rgba(0,0,0,0.05);
        "
      >

        <p
          class="mb-0"
          style="
            color: #5f6b73;
            font-size: 1.1rem;
            font-weight: 600;
          "
        >
          No hay proyectos pendientes de aprobación.
        </p>

      </div>

    <% } %>

  </div>

</body>

<%- include("../partials/footer.ejs") %>