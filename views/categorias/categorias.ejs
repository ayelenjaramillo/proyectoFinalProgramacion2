<%- include("../partials/header.ejs") %>

<body style="background-color: #f8fafb;">

  <%- include("../partials/navbar.ejs") %>

  <div class="container py-5">

    <div class="text-center mb-5">

      <p class="mb-2" style="
                color: #21708c;
                font-weight: 700;
                letter-spacing: 1px;
                text-transform: uppercase;
                font-size: 14px;
            ">
        Feria Provincial
      </p>

      <h1 class="fw-bold" style="
                font-size: clamp(2.8rem, 5vw, 4rem);
            ">
        <%= titulo %>
      </h1>

      <p class="mt-3" style="
                color: #5f6b73;
                font-size: 1.05rem;
            ">
        Explorá los proyectos según su categoría.
      </p>

    </div>

    <div class="d-flex flex-wrap justify-content-center gap-4">

      <% categoria.forEach(categ => { %>

      <a href="/categorias/categoria/<%= categ.id %>" class="text-decoration-none">

        <div class="d-flex flex-column align-items-center justify-content-center" style="
                        width: 170px;
                        height: 170px;
                        background-color: white;
                        border-radius: 28px;
                        box-shadow: 0 10px 25px rgba(0,0,0,0.06);
                        transition: 0.2s ease;
                        cursor: pointer;
                    " onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">


          <p class="mb-0 text-center" style="
                            color: #263238;
                            font-weight: 700;
                            font-size: 1rem;
                        ">
            <%= categ.nombre %>
          </p>

        </div>

      </a>

      <% }); %>

    </div>

  </div>

  <%- include("../partials/footer.ejs") %>