<%- include("../partials/header.ejs") %>

<body style="background-color: #f8fafb;">

<%- include("../partials/navbar.ejs") %>

<div class="container py-5">

    <div class="text-center mb-5">

        <p 
            class="mb-2"
            style="
                color: #21708c;
                font-weight: 700;
                letter-spacing: 1px;
                text-transform: uppercase;
                font-size: 14px;
            "
        >
            Categoría
        </p>
        <div 
        class="d-flex align-items-center justify-content-center gap-3"
    >
    
        <h1 
            class="fw-bold mb-0"
            style="
                font-size: clamp(3rem, 5vw, 4.5rem);
            "
        >
            <%= categoria.nombre %>
        </h1>
    
   
    
    </div>

        <p 
            class="mt-3"
            style="
                color: #5f6b73;
                font-size: 1.05rem;
            "
        >
            Explorá todos los proyectos pertenecientes a esta categoría.
        </p>

    </div>

    <% if(categoria.proyectos && categoria.proyectos.length > 0){ %>

        <div class="d-flex flex-column gap-4">

            <% categoria.proyectos.forEach(proyecto => { %>

                <div 
                class="p-4 d-flex flex-column flex-lg-row justify-content-between align-items-end align-items-lg-center"
                    style="
                        background-color: white;
                        border-radius: 24px;
                        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
                    "
                >

                    <div>

                        <h3 
                            class="fw-bold mb-3"
                            style="
                                font-size: 1.8rem;
                                color: #1f2d33;
                            "
                        >
                            <%= proyecto.titulo %>
                        </h3>

                        <p 
                            class="mb-3"
                            style="
                                color: #5f6b73;
                                line-height: 1.8;
                                max-width: 850px;
                            "
                        >
                            <%= proyecto.descripcion %>
                        </p>

                    </div>

                    <div class="mt-4 mt-lg-0">

                        <a 
                        href="/proyectos/<%= proyecto.id %>"
                        class="d-flex align-items-center justify-content-center text-decoration-none"
                        style="
                            width: 60px;
                            height: 60px;
                            background-color: #21708c;
                            color: white;
                            border-radius: 50%;
                            font-size: 1.4rem;
                            transition: 0.2s ease;
                        "
                        onmouseover="this.style.transform='translateX(4px)'"
                        onmouseout="this.style.transform='translateX(0)'"
                    >
                    
                        <i class="bi bi-arrow-right"></i>
                    
                    </a>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } else { %>

        <div 
            class="d-flex align-items-center justify-content-center"
            style="
                min-height: 250px;
                background-color: white;
                border-radius: 28px;
                box-shadow: 0 12px 30px rgba(0,0,0,0.05);
            "
        >

            <p 
                class="mb-0"
                style="
                    color: #5f6b73;
                    font-size: 1.1rem;
                    font-weight: 600;
                "
            >
                No hay proyectos cargados en esta categoría.
            </p>

        </div>

    <% } %>

</div>

<%- include("../partials/footer.ejs") %>