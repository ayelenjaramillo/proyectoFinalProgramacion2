<%- include("../partials/header.ejs") %>

<body style="background-color: #f8fafb;">
  <%- include("../partials/navbar.ejs") %>
  <main class="d-flex align-items-center justify-content-center py-5" style="min-height: calc(100vh - 90px);">

    <div class="container py-5">

      <div class="row justify-content-center">

        <div class="col-md-8 col-lg-6">

          <div class="card shadow-sm border-0">


            <div class="card-header text-center py-4" style="background-color: #21708c;">

              <h3 class="fw-bold text-white mb-0">
                <%= titulo %>
              </h3>

            </div>

            <% if (proyecto.imagenes && proyecto.imagenes.length > 0) { %>

            <div class="mb-5">

              <div class="d-flex align-items-center justify-content-between mb-4">

                <h5 class="fw-bold mb-0" style="
                            color: #1f2d33;
                        ">
                  Imágenes actuales
                </h5>

                <span class="px-3 py-2 rounded-pill mt-5" style="
                            background-color: #eef5f7;
                            color: #21708c;
                            font-weight: 700;
                            font-size: 14px;
                        ">
                  <%= proyecto.imagenes.length %> imágenes
                </span>

              </div>

              <div class="row g-4">

                <% proyecto.imagenes.forEach(img => { %>

                <div class="col-6 col-md-4">

                  <div class="position-relative overflow-hidden" style="
                                border-radius: 22px;
                                box-shadow: 0 10px 25px rgba(0,0,0,0.08);
                            ">

                    <img src="<%= img.filename %>" alt="Imagen del proyecto" class="img-fluid w-100" style="
                                    height: 180px;
                                    object-fit: cover;
                                ">

                    <form method="POST" action="/proyectos/<%= proyecto.id %>/imagenes/<%= img.id %>/eliminar" class="position-absolute top-0 end-0 p-2">

                      <button type="submit" onclick="return confirm('¿Eliminar esta imagen?')" style="
                                        width: 38px;
                                        height: 38px;
                                        border: none;
                                        border-radius: 50%;
                                        background-color: rgba(220,53,69,0.95);
                                        color: white;
                                        font-weight: bold;
                                        font-size: 18px;
                                        cursor: pointer;
                                    ">
                        ×
                      </button>

                    </form>

                  </div>

                </div>

                <% }) %>

              </div>

            </div>

            <% } else { %>

            <div class="mb-5 d-flex align-items-center justify-content-center" style="
                    min-height: 180px;
                    background-color: #eef2f4;
                    border-radius: 24px;
                ">

              <p class="mb-0" style="
                        color: #5f6b73;
                        font-weight: 600;
                        font-size: 1rem;
                    ">
                Todavía no existen imágenes para este proyecto
              </p>

            </div>

            <% } %>
            <div class="card-body p-4">

              <form action="/proyectos/<%= proyecto.id %>/editar" method="POST" enctype="multipart/form-data">


                <div class="mb-3">

                  <label class="form-label">
                    Título del proyecto
                  </label>

                  <input type="text" name="titulo" class="form-control" placeholder="Ingresá el nombre de tu proyecto" value="<%= proyecto.titulo %>" />

                </div>


                <div class="mb-3">

                  <label class="form-label">
                    Descripción
                  </label>

                  <textarea name="descripcion" class="form-control" rows="4" placeholder="Agregá una breve descripción de tu proyecto"><%= proyecto.descripcion %></textarea>

                </div>


                <div class="mb-3">

                  <label for="categoria_id" class="form-label">
                    Categoría
                  </label>

                  <select name="categoria_id" id="categoria_id" class="form-select">

                    <option value="">
                      Seleccioná la categoría de tu proyecto
                    </option>

                    <% categorias.forEach(categoria => { %>

                    <option value="<%= categoria.id %>" <%= proyecto.categoria_id == categoria.id ? "selected" : "" %>>
                      <%= categoria.nombre %>
                    </option>

                    <% }) %>

                  </select>

                </div>


                <div class="mb-4">

                  <label for="escuela_id" class="form-label">
                    Escuela
                  </label>

                  <select name="escuela_id" id="escuela_id" class="form-select">

                    <option value="">
                      Seleccioná la escuela a la que pertenecés
                    </option>

                    <% escuelas.forEach(esc => { %>
                    <option value="<%= esc.id %>" <%= proyecto.escuela_id == esc.id ? "selected" : "" %>>
                      <%= esc.padron %>
                    </option>

                    <% }) %>

                  </select>

                </div>

                <div class="mb-4">
                  <label class="form-label">
                    Cambiar o agregar imágenes al proyecto
                  </label>

                  <input type="file" name="imagenes" class="form-control" accept="image/*" multiple />
                </div>

                <button type="submit" class="btn text-white w-100" style="background-color: #21708c; font-weight: 700;">
                  Editá tu proyecto
                </button>

              </form>

            </div>

          </div>

        </div>

      </div>

    </div>

    <%- include("../partials/footer.ejs") %>