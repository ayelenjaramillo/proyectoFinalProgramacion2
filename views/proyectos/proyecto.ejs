<%- include("../partials/header.ejs") %>

<body style="background-color: #f8fafb;">

<%- include("../partials/navbar.ejs") %>

<main 
    class="d-flex align-items-center justify-content-center py-5"
    style="min-height: calc(100vh - 90px);"
>

  <div class="container py-5">
    <section class="p-4 p-lg-5 mb-5" style="
            background-color: white;
            border-radius: 28px;
            box-shadow: 0 12px 30px rgba(0,0,0,0.06);
        ">
      <div class="row align-items-center g-5">
        <div class="col-lg-6">
          <a href="/categorias/categoria/<%= proyecto.categoria.id %>" class="text-decoration-none px-3 py-2 rounded-pill d-inline-block mb-4" style="
                        background-color: #5894a7;
                        color: white;
                        font-weight: 700;
                        font-size: 13px;
                    ">
            <%= proyecto.categoria.nombre %>
          </a>
          <h1 class="fw-bold mb-4" style="
                        font-size: clamp(3rem, 5vw, 4.5rem);
                        line-height: 1.1;
                    ">
            <%= proyecto.titulo %>
          </h1>
          <p class="mb-5" style="
                        font-size: 1.1rem;
                        line-height: 1.8;
                        color: #5f6b73;
                    ">
            <%= proyecto.descripcion %>
          </p>
          <div class="d-inline-flex align-items-center gap-2 px-4 py-3 rounded-4" style="
                        background-color: #eef5f7;
                    ">

            <span style="
                            width: 12px;
                            height: 12px;
                            background-color: #21708c;
                            border-radius: 50%;
                            display: inline-block;
                        "></span>

            <p class="mb-0" style="
                            color: #47606b;
                            font-weight: 600;
                        ">
              Escuela N.º <%= proyecto.escuela.padron %>
            </p>

          </div>

        </div>
        <div class="col-lg-6">

          <% if (proyecto.imagenes && proyecto.imagenes.length > 0) { %>

          <img src="/img/proyectos/<%= proyecto.imagenes[0].filename %>" alt="Proyecto" class="img-fluid w-100" style="
                            border-radius: 28px;
                            object-fit: cover;
                            max-height: 450px;
                            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
                        ">

          <% } else { %>

          <img src="/home.jpg" alt="Proyecto" class="img-fluid w-100" style="
                            border-radius: 28px;
                            object-fit: cover;
                            max-height: 450px;
                            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
                        ">
          <% } %>

        </div>

      </div>

    </section>
    <% if (proyecto.imagenes && proyecto.imagenes.length > 1) { %>

    <section class="mb-5">

      <h3 class="fw-bold mb-4" style="
                color: #1d2a30;
            ">
        Galería del proyecto
      </h3>

      <div class="row g-4">

        <% proyecto.imagenes.slice(1).forEach(imagen => { %>

        <div class="col-md-6 col-lg-4">

          <img src="/img/proyectos/<%= imagen.filename %>" alt="Proyecto" class="img-fluid w-100" style="
                        border-radius: 22px;
                        height: 250px;
                        object-fit: cover;
                        box-shadow: 0 10px 25px rgba(0,0,0,0.06);
                    ">
        </div>
        <% }) %>
      </div>
    </section>
    <% } %>
    <div class="d-flex flex-wrap justify-content-center gap-3">

      <a href="/proyectos/<%= proyecto.id %>/editar" class="btn px-4 py-3" style="
                background-color: #21708c;
                color: white;
                font-weight: 700;
                border-radius: 14px;
            ">
        Editar proyecto
      </a>

      <a href="/proyectos" class="btn px-4 py-3" style="
                border: 2px solid #ced6da;
                color: #4f6169;
                font-weight: 700;
                border-radius: 14px;
                background-color: white;
            ">
        Volver
      </a>
      <form action="/proyectos/<%= proyecto.id %>/eliminar" method="POST">
        <button type="submit" class="btn px-4 py-3" style="
                    border: 2px solid #dc3545;
                    color: #dc3545;
                    font-weight: 700;
                    border-radius: 14px;
                    background-color: white;
                ">
          Eliminar proyecto
        </button>
      </form>
    </div>
  </div>
  <%- include("../partials/footer.ejs") %>