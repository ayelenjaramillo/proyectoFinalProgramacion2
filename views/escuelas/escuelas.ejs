<%- include("../partials/header.ejs") %>


<body style="background-color: #f8fafb;">
    <%- include("../partials/navbar.ejs") %>
    <main class="d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 90px);">
    
<div class="container py-5">

 
    <div class="d-flex justify-content-between align-items-center mb-5">

        <div>

            <p 
                class="mb-2"
                style="
                    color: #21708c;
                    font-weight: 700;
                    letter-spacing: 1px;
                    text-transform: uppercase;
                    font-size: 14px;
                "
            >
                Escuelas participantes
            </p>

            <h1 class="display-5 fw-bold mb-0">
                <%= titulo %>
            </h1>

        </div>

        <a 
            href="/escuelas/nuevo" 
            class="btn px-4 py-2"
            style="
                background-color: #21708c;
                color: white;
                font-weight: 700;
                border-radius: 14px;
            "
        >
            Agregar escuela
        </a>

    </div>


    <div class="row g-4">

        <% escuela.forEach(esc => { %>

        <div class="col-md-6 col-lg-4">

            <div 
                class="card border-0 h-100 overflow-hidden"
                style="
                    border-radius: 24px;
                    box-shadow: 0 10px 25px rgba(0,0,0,0.06);
                "
            >

                <div 
                    style="
                        height: 6px;
                        background-color: #21708c;
                    "
                ></div>

      
                <div 
                    class="card-header border-0 text-center py-4"
                    style="
                        background-color: white;
                    "
                >

                    <div 
                        class="mx-auto d-flex align-items-center justify-content-center rounded-circle"
                        style="
                            width: 85px;
                            height: 85px;
                            background-color: #eef5f7;
                            border: 3px solid #d7e6ec;
                        "
                    >

                        <img 
                            src="/home.jpg" 
                            alt="Logo escuela"
                            class="rounded-circle"
                            width="65"
                            height="65"
                            style="
                                object-fit: cover;
                            "
                        >

                    </div>

                </div>

                <div class="card-body text-center px-4 pb-4">

                    <h4 
                        class="fw-bold mb-3"
                        style="
                            color: #1d2a30;
                        "
                    >
                        <%= esc.nombre %>
                    </h4>

                    <div class="mb-4">

                        <p 
                            class="mb-2"
                            style="
                                color: #5f6b73;
                            "
                        >
                            <strong>Región:</strong>
                            <%= esc.region.nombre %>
                        </p>

                        <p 
                            class="mb-0"
                            style="
                                color: #5f6b73;
                            "
                        >
                            <strong>Localidad:</strong>
                            <%= esc.localidad %>
                        </p>

                    </div>

                    <a 
                        href="/escuelas/<%= esc.id %>" 
                        class="btn w-100"
                        style="
                            background-color: #21708c;
                            color: white;
                            font-weight: 700;
                            border-radius: 14px;
                            padding: 12px;
                        "
                    >
                        Ver detalle de escuela
                    </a>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

</div>
</main>
<%- include("../partials/footer.ejs") %>